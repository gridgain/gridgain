<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs include filter — covers all seven CWE classes Barclays' Veracode flagged in
    the 2026-04-28 ignite-h2 report (CS-43297, 37 flaws). Used by the "sast" Maven profile
    in modules/h2 to prove GG-side SAST visibility before any source fix lands.
    See projects/barclays-veracode-h2 (assistant repo) for context.

    Detector → CWE map (37 Veracode flaws):
      SQL_INJECTION_*, SQL_NONCONSTANT_*, SQL_PREPARED_*  → CWE-89  (21 flaws)
      OBJECT_DESERIALIZATION, DESERIALIZATION_GADGET      → CWE-502 (3)
      XXE_*                                               → CWE-611 (2)
      XSS_*                                               → CWE-80  (2)
      HARD_CODE_PASSWORD, DMI_CONSTANT_DB_PASSWORD,
      DMI_EMPTY_DB_PASSWORD                               → CWE-259, CWE-798 (2 total)
      HARD_CODE_KEY                                       → CWE-321 (bonus: crypto-key
                                                                    plaintext, related to
                                                                    CWE-256 plaintext storage)
      COMMAND_INJECTION                                   → CWE-78  (0 in this Veracode
                                                                    scan; kept as insurance)

    Note on CWE-256 (Plaintext Storage of Password — 7 Veracode flaws): FindSecurityBugs
    1.14.0 has no single dedicated detector for arbitrary plaintext password storage. The
    HARD_CODE_PASSWORD + DMI_CONSTANT_DB_PASSWORD pair catches a common subset
    (hard-coded passwords in source / DB connection strings). True plaintext-at-rest
    storage flaws may need manual review or a Veracode-only signal.
-->
<FindBugsFilter>
    <!-- CWE-89: SQL Injection -->
    <Match>
        <Bug pattern="SQL_INJECTION_JDBC,SQL_INJECTION_HIBERNATE,SQL_INJECTION_JDO,SQL_INJECTION_JPA,SQL_INJECTION_SPRING_JDBC,SQL_INJECTION_TURBINE,SQL_INJECTION_VERTX,SQL_INJECTION_ANDROID,SQL_NONCONSTANT_STRING_PASSED_TO_EXECUTE,SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/>
    </Match>
    <!-- CWE-502: Untrusted Deserialization -->
    <Match>
        <Bug pattern="OBJECT_DESERIALIZATION,DESERIALIZATION_GADGET"/>
    </Match>
    <!-- CWE-611: XML External Entity -->
    <Match>
        <Bug pattern="XXE_DOCUMENT,XXE_SAXPARSER,XXE_XMLREADER,XXE_XMLSTREAMREADER,XXE_XPATH,XXE_DTD_TRANSFORM_FACTORY"/>
    </Match>
    <!-- CWE-78: Command Injection -->
    <Match>
        <Bug pattern="COMMAND_INJECTION"/>
    </Match>
    <!-- CWE-80: Basic XSS / Improper Neutralization of Script-Related HTML Tags -->
    <Match>
        <Bug pattern="XSS_REQUEST_PARAMETER_TO_SEND_ERROR,XSS_REQUEST_PARAMETER_TO_SERVLET_WRITER,XSS_REQUEST_PARAMETER_TO_JSP_WRITER,XSS_JSP_PRINT,XSS_SERVLET"/>
    </Match>
    <!-- CWE-259, CWE-798: Hard-coded credentials / passwords (DMI_* detectors come from
         core SpotBugs; HARD_CODE_* from FindSecurityBugs). HARD_CODE_KEY is a bonus
         (CWE-321 hard-coded crypto key) since the plaintext-storage Veracode set may
         include key material. -->
    <Match>
        <Bug pattern="HARD_CODE_PASSWORD,HARD_CODE_KEY,DMI_CONSTANT_DB_PASSWORD,DMI_EMPTY_DB_PASSWORD"/>
    </Match>
</FindBugsFilter>
