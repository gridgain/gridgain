<!--
    POM file.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.gridgain</groupId>
        <artifactId>ignite-parent-internal</artifactId>
        <version>8.10.127-SNAPSHOT</version>
        <relativePath>../../parent-internal/pom.xml</relativePath>
    </parent>

    <artifactId>ignite-lucene-10</artifactId>
    <version>8.10.127-SNAPSHOT</version>

    <properties>
        <!-- Base classes compile at 21 (Lucene 10's floor). The FFM no-copy overlay in
             src/main/java22 compiles at 22 into META-INF/versions/22 (see build/plugins). -->
        <maven.compiler.target>21</maven.compiler.target>
        <maven.compiler.release>21</maven.compiler.release>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.gridgain</groupId>
            <artifactId>ignite-core</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>org.gridgain</groupId>
            <artifactId>ignite-h2</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>org.apache.lucene</groupId>
            <artifactId>lucene-core</artifactId>
            <version>${lucene10.version}</version>
        </dependency>

        <dependency>
            <groupId>org.apache.lucene</groupId>
            <artifactId>lucene-analysis-common</artifactId>
            <version>${lucene10.version}</version>
        </dependency>

        <dependency>
            <groupId>org.apache.lucene</groupId>
            <artifactId>lucene-queries</artifactId>
            <version>${lucene10.version}</version>
        </dependency>

        <dependency>
            <groupId>org.apache.lucene</groupId>
            <artifactId>lucene-queryparser</artifactId>
            <version>${lucene10.version}</version>
        </dependency>

        <dependency>
            <groupId>org.gridgain</groupId>
            <artifactId>ignite-core</artifactId>
            <version>${project.version}</version>
            <type>test-jar</type>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.gridgain</groupId>
            <artifactId>ignite-tools</artifactId>
            <version>${project.version}</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>log4j</groupId>
            <artifactId>log4j</artifactId>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-core</artifactId>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-beans</artifactId>
            <version>${spring.version}</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-context</artifactId>
            <version>${spring.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>src/main/java</directory>
                <excludes>
                    <exclude>**/*.java</exclude>
                </excludes>
            </resource>

            <resource>
                <directory>src/main/resources</directory>
            </resource>
        </resources>

        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-deploy-plugin</artifactId>
                <version>2.8.2</version>
                <configuration>
                    <skip>false</skip>
                </configuration>
            </plugin>

            <!-- Shared GridLucene* base sources (identical across Lucene 9.10 and 10.4) live once in
                 ../lucene-9-10-common and are compiled here against Lucene 10.4. The FFM no-copy overlay
                 in src/main/java22 (below) is the only lucene-10-specific code. -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.6.1</version>
                <executions>
                    <execution>
                        <id>add-shared-lucene-source</id>
                        <phase>generate-sources</phase>
                        <goals><goal>add-source</goal></goals>
                        <configuration>
                            <sources><source>${project.basedir}/../lucene-9-10-common/src/main/java</source></sources>
                        </configuration>
                    </execution>
                    <execution>
                        <id>add-shared-lucene-test-source</id>
                        <phase>generate-test-sources</phase>
                        <goals><goal>add-test-source</goal></goals>
                        <configuration>
                            <sources><source>${project.basedir}/../lucene-9-10-common/src/test/java</source></sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Base classes compile at release 21 (Lucene 10's floor). Pin a modern compiler; the
                 parent's 3.1 predates the release/multi-release options. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- The FFM no-copy scorer uses java.lang.foreign, which is non-preview only on JDK 22+. When
             built on JDK 22+, compile the src/main/java22 overlay into META-INF/versions/22 and mark the
             jar multi-release, so a Java 22+ runtime auto-loads the no-copy scorer. On JDK 21 this profile
             is inactive and the module builds base-only (Lucene 10 + readFloats) — which still runs on 21+.
             So the module builds on JDK 21+ and only *gains* the no-copy overlay when built on 22+. -->
        <profile>
            <id>nocopy-java22-overlay</id>
            <activation>
                <jdk>[22,)</jdk>
            </activation>

            <!-- Compile the tests at release 22 as well, so the no-copy test may reference
                 java.lang.foreign (final in 22, preview in 21). Base/main sources still compile at
                 release 21 (see the maven.compiler.release property above). -->
            <properties>
                <maven.compiler.testRelease>22</maven.compiler.testRelease>
            </properties>

            <build>
                <plugins>
                    <!-- Add the release-22 no-copy test sources (mirrors src/main/java22). -->
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>build-helper-maven-plugin</artifactId>
                        <version>3.6.1</version>
                        <executions>
                            <execution>
                                <id>add-nocopy-test-source</id>
                                <phase>generate-test-sources</phase>
                                <goals><goal>add-test-source</goal></goals>
                                <configuration>
                                    <sources><source>${project.basedir}/src/test/java22</source></sources>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-compiler-plugin</artifactId>
                        <version>3.13.0</version>
                        <executions>
                            <execution>
                                <id>compile-java22-nocopy</id>
                                <phase>compile</phase>
                                <goals>
                                    <goal>compile</goal>
                                </goals>
                                <configuration>
                                    <release>22</release>
                                    <multiReleaseOutput>true</multiReleaseOutput>
                                    <compileSourceRoots>
                                        <compileSourceRoot>${project.basedir}/src/main/java22</compileSourceRoot>
                                    </compileSourceRoots>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-jar-plugin</artifactId>
                        <configuration>
                            <archive>
                                <manifestEntries>
                                    <Multi-Release>true</Multi-Release>
                                </manifestEntries>
                            </archive>
                        </configuration>
                    </plugin>

                    <!-- The overlay only shadows the base when classes load from the multi-release JAR
                         (exploded target/classes never applies META-INF/versions/ versioning). So the
                         no-copy *IT runs under failsafe against the packaged jar, after 'package' builds it,
                         rather than under surefire against target/classes. The enable-native-access argLine
                         silences the restricted-method (MemorySegment.reinterpret) warning. -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-failsafe-plugin</artifactId>
                        <version>3.5.4</version>
                        <configuration>
                            <classesDirectory>${project.build.directory}/${project.build.finalName}.jar</classesDirectory>
                            <!-- GridUnsafe needs Ignite's module-access flags (the parent applies these to
                                 surefire, not failsafe); enable-native-access silences the MemorySegment
                                 restricted-method warning. -->
                            <argLine>
                                --add-opens=java.base/jdk.internal.access=ALL-UNNAMED
                                --add-opens=java.base/jdk.internal.misc=ALL-UNNAMED
                                --add-opens=java.base/sun.nio.ch=ALL-UNNAMED
                                --add-opens=java.base/java.io=ALL-UNNAMED
                                --add-opens=java.base/java.nio=ALL-UNNAMED
                                --add-opens=java.base/java.util=ALL-UNNAMED
                                --add-opens=java.base/java.lang=ALL-UNNAMED
                                --enable-native-access=ALL-UNNAMED
                            </argLine>
                        </configuration>
                        <executions>
                            <execution>
                                <goals>
                                    <goal>integration-test</goal>
                                    <goal>verify</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
