<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs + FindSecBugs include filter for the security CWE classes
  we care about in the vendored H2 fork:

    CWE-80   Reflected/basic cross-site scripting
    CWE-89   SQL injection
    CWE-259  Hard-coded password
    CWE-502  Deserialization of untrusted data
    CWE-611  XML external entity (XXE)
    CWE-798  Use of hard-coded credentials

  Used by the static-analysis profile in modules/h2/pom.xml.
-->
<FindBugsFilter>
    <!-- CWE-89: SQL Injection -->
    <Match><Bug pattern="SQL_INJECTION"/></Match>
    <Match><Bug pattern="SQL_INJECTION_JDBC"/></Match>
    <Match><Bug pattern="SQL_INJECTION_JPA"/></Match>
    <Match><Bug pattern="SQL_INJECTION_HIBERNATE"/></Match>
    <Match><Bug pattern="SQL_INJECTION_SPRING_JDBC"/></Match>
    <Match><Bug pattern="SQL_INJECTION_TURBINE"/></Match>
    <Match><Bug pattern="SQL_INJECTION_VERTX"/></Match>
    <Match><Bug pattern="SQL_INJECTION_ANDROID"/></Match>
    <Match><Bug pattern="SQL_NONCONSTANT_STRING_PASSED_TO_EXECUTE"/></Match>
    <Match><Bug pattern="SQL_PREPARED_STATEMENT_GENERATED_FROM_NONCONSTANT_STRING"/></Match>

    <!-- CWE-259 / CWE-798: Hard-coded credentials -->
    <Match><Bug pattern="HARD_CODE_PASSWORD"/></Match>
    <Match><Bug pattern="HARD_CODE_KEY"/></Match>
    <Match><Bug pattern="DMI_HARDCODED_ABSOLUTE_FILENAME"/></Match>

    <!-- CWE-80: Cross-site scripting (basic) -->
    <Match><Bug pattern="XSS_REQUEST_PARAMETER_TO_SEND_ERROR"/></Match>
    <Match><Bug pattern="XSS_REQUEST_PARAMETER_TO_SERVLET_WRITER"/></Match>
    <Match><Bug pattern="XSS_REQUEST_PARAMETER_TO_JSP_WRITER"/></Match>
    <Match><Bug pattern="XSS_SERVLET"/></Match>
    <Match><Bug pattern="XSS_JSP_PRINT"/></Match>

    <!-- CWE-502: Deserialization of untrusted data -->
    <Match><Bug pattern="OBJECT_DESERIALIZATION"/></Match>
    <Match><Bug pattern="DESERIALIZATION_GADGET"/></Match>

    <!-- CWE-611: XML External Entity / XXE -->
    <Match><Bug pattern="XXE_DOCUMENT"/></Match>
    <Match><Bug pattern="XXE_SAXPARSER"/></Match>
    <Match><Bug pattern="XXE_XMLREADER"/></Match>
    <Match><Bug pattern="XXE_XMLSTREAMREADER"/></Match>
    <Match><Bug pattern="XXE_XPATH"/></Match>
    <Match><Bug pattern="XXE_DTD_TRANSFORM_FACTORY"/></Match>
    <Match><Bug pattern="XXE_XSLT_TRANSFORM_FACTORY"/></Match>
</FindBugsFilter>
