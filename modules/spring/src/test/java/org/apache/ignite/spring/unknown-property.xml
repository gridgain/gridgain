<!--
    GridGain Spring configuration that sets a configuration property which does not exist on the target
    bean. Mimics an Ignite-only property left in the config of a user migrating to GridGain.
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="grid.cfg" class="org.apache.ignite.configuration.IgniteConfiguration">
        <property name="transactionConfiguration">
            <bean class="org.apache.ignite.configuration.TransactionConfiguration">
                <!-- Ignite-only property that does not exist on GridGain's TransactionConfiguration. -->
                <property name="txAwareQueriesEnabled" value="true"/>
            </bean>
        </property>
    </bean>
</beans>
